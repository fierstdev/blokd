{
  "name": "blokd",
  "version": "0.1.0-beta.1",
  "description": "Blokd: tiny production-oriented Hono-native meta-framework with Solid-familiar signals, Web APIs, SSR, routing, and resumable islands.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js",
      "default": "./dist/core.js"
    },
    "./dom": {
      "types": "./dist/dom.d.ts",
      "import": "./dist/dom.js",
      "default": "./dist/dom.js"
    },
    "./jsx-runtime": {
      "types": "./dist/jsx-runtime.d.ts",
      "import": "./dist/jsx-runtime.js",
      "default": "./dist/jsx-runtime.js"
    },
    "./jsx-dev-runtime": {
      "types": "./dist/jsx-runtime.d.ts",
      "import": "./dist/jsx-runtime.js",
      "default": "./dist/jsx-runtime.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "default": "./dist/server.js"
    },
    "./hono": {
      "types": "./dist/hono.d.ts",
      "import": "./dist/hono.js",
      "default": "./dist/hono.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js",
      "default": "./dist/vite.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "default": "./dist/client.js"
    },
    "./resume": {
      "types": "./dist/resume.d.ts",
      "import": "./dist/resume.js",
      "default": "./dist/resume.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-license.mjs"
  },
  "dependencies": {
    "@babel/core": ">=7.24 <8",
    "hono": ">=4.5 <5"
  },
  "devDependencies": {
    "@types/node": ">=20 <23",
    "typescript": ">=5.5 <6",
    "vite": ">=6 <9"
  },
  "peerDependencies": {
    "vite": ">=6 <9"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "keywords": [
    "hono",
    "ssr",
    "jsx",
    "signals",
    "resumability",
    "meta-framework"
  ],
  "engines": {
    "node": ">=20.19"
  }
}
