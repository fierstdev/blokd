{
  "name": "blokd-workspace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "tsc -b && pnpm --filter blokd build",
    "test": "vitest run",
    "check": "pnpm build && pnpm test && node scripts/verify-package.mjs && node scripts/size-budget.mjs",
    "build:restaurant": "pnpm --filter blokd-restaurant build",
    "start:restaurant": "pnpm --filter blokd-restaurant start",
    "build:site": "pnpm --filter blokd-dev-site build",
    "smoke:site": "node scripts/smoke-blokd-dev-build.mjs",
    "test:browser": "playwright test",
    "smoke:restaurant": "node scripts/smoke-restaurant-build.mjs",
    "pack:dry-run": "node scripts/publish-dry-run.mjs",
    "create:smoke": "node packages/create-blokd/bin/create-blokd.js /tmp/blokd-create-smoke --template minimal --no-install"
  },
  "devDependencies": {
    "@babel/core": ">=7.24 <8",
    "@hono/node-server": ">=1.13 <3",
    "@types/babel__core": ">=7.20 <8",
    "@types/node": ">=20 <27",
    "hono": ">=4.5 <5",
    "typescript": ">=5.5 <7",
    "vite": ">=6 <9",
    "vitest": ">=2 <5",
    "@playwright/test": ">=1.44 <2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ]
  },
  "workspaces": [
    "packages/*",
    "examples/*"
  ]
}
